      "documentation" : {
        "en" : {
          "/items[at0066.1]" : {
            "mapTargetName" : "periodOfUse",
            "mapTargetFhirPath" : "EHDSMedicationStatement.periodOfUse",
            "mapTargetDefinition" : "Period when patient took, is taking or is expected to take the medication. This information may be expressed using start and end date times OR indicating the duration. The first is used to indicate a specified interval (e.g., from March 15th, 2017); the latter for indicating a 'floating' period (e.g., 2 weeks). In case of unbounded period (continuous therapy), the end element will be valued with an exceptional value.",
            "mapTargetCardinality" : "0..1"
          },
