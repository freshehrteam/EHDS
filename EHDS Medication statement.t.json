  "annotations" : {
    "@type" : "RESOURCE_ANNOTATIONS",
    "documentation" : {
      "en" : {
        "" : {
          "mapTargetName" : "EHDSMedicationStatement",
          "mapTargetFhirPath" : "EHDSMedicationStatement",
          "mapTargetDefinition" : "Statement about a single medication as part of a medication summary.",
          "mapTargetCardinality" : "0..*"
        },
        "/data[at0001]/events[at0002.1]/data[at0003]/items[at0023.1]" : {
          "mapTargetName" : "medicationReason",
          "mapTargetFhirPath" : "EHDSMedicationStatement.medicationReason",
          "mapTargetDefinition" : "Coded reason for the use of the medication (typically diagnosis, or a procedure)",
          "mapTargetCardinality" : "0..*"
        },
        "/data[at0001]/events[at0002.1]/data[at0003]/items[at0006.1]" : {
          "mapTargetName" : "productName",
          "mapTargetFhirPath" : "EHDSMedication.productName",
          "mapTargetDefinition" : "Name of the product (full name, invented name, other). When the product has different names, the appropriate one for the context should be used. Translations of names can be provided.",
          "mapTargetCardinality" : "0..1"
        },
        "/data[at0001]/events[at0002.1]/data[at0003]/items[at0037.1]" : {
          "mapTargetName" : "periodOfUse",
          "mapTargetFhirPath" : "EHDSMedicationStatement.periodOfUse",
          "mapTargetDefinition" : "Period when patient took, is taking or is expected to take the medication. This information may be expressed using start and end date times OR indicating the duration. The first is used to indicate a specified interval (e.g., from March 15th, 2017); the latter for indicating a 'floating' period (e.g., 2 weeks). In case of unbounded period (continuous therapy), the end element will be valued with an exceptional value.",
          "mapTargetCardinality" : "0..1"
        }
      }
    }
  },
