  "templateOverlays" : [ {
    "@type" : "TEMPLATE_OVERLAY",
    "uid" : "8c5e6e3e-80d5-4dd5-99bb-3c90ee031930",
    "description" : {
      "@type" : "RESOURCE_DESCRIPTION",
      "originalAuthor" : { },
