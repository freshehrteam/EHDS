  "annotations" : {
    "@type" : "RESOURCE_ANNOTATIONS",
    "documentation" : {
      "en" : {
        "" : {
          "mapTargetName" : "AllergyIntolerance",
          "mapTargetFhirPath" : "AllergyIntolerance",
          "mapTargetDefinition" : "Risk of harmful or undesirable, physiological response which is unique to an individual and associated with exposure to a substance.",
          "mapTargetCardinality" : "0..*"
        },
        "/data[at0001]/items[at0002.1]" : {
          "mapTargetName" : "code",
          "mapTargetFhirPath" : "AllergyIntolerance.code",
          "mapTargetDefinition" : "Code for an allergy or intolerance statement (either a positive or a negated/excluded statement). This may be a code for a substance or pharmaceutical product that is considered to be responsible for the adverse reaction risk (e.g., \"Latex\"), an allergy or intolerance condition (e.g., \"Latex allergy\"), or a negated/excluded code for a specific substance or class (e.g., \"No latex allergy\") or a general or categorical negated statement (e.g., \"No known allergy\", \"No known drug allergies\"). Note: the substance for a specific reaction may be different from the substance identified as the cause of the risk, but it must be consistent with it. For instance, it may be a more specific substance (e.g. a brand medication) or a composite product that includes the identified substance. It must be clinically safe to only process the 'code' and ignore the 'reaction.substance'. If a receiving system is unable to confirm that AllergyIntolerance.reaction.substance falls within the semantic scope of AllergyIntolerance.code, then the receiving system should ignore AllergyIntolerance.reaction.substance.",
          "mapTargetBindings" : "The codes SHOULD be taken from Allergies & Intolerances - IPS (preferred to http://hl7.org/fhir/uv/ips/ValueSet/allergies-intolerances-uv-ips) Type of the substance/product, allergy or intolerance condition or a code for absent/unknown allergy.",
          "mapTargetCardinality" : "1..1"
        },
        "/data[at0001]/items[at0130.1]" : {
          "mapTargetName" : "clinicalStatus",
          "mapTargetFhirPath" : "AllergyIntolerance.clinicalStatus",
          "mapTargetDefinition" : "The clinical status of the allergy or intolerance.",
          "mapTargetBindings" : "The codes SHALL be taken from AllergyIntoleranceClinicalStatusCodes (required to http://hl7.org/fhir/ValueSet/allergyintolerance-clinical|4.0.1) The clinical status of the allergy or intolerance.",
          "mapTargetCardinality" : "0..1"
        },
        "/data[at0001]/items[at0063]" : {
          "mapTargetName" : "verificationStatus",
          "mapTargetFhirPath" : "AllergyIntolerance.verificationStatus",
          "mapTargetDefinition" : "Assertion about certainty associated with the propensity, or potential risk, of a reaction to the identified substance (including pharmaceutical product).",
          "mapTargetBindings" : "The codes SHALL be taken from AllergyIntoleranceVerificationStatusCodes (required to http://hl7.org/fhir/ValueSet/allergyintolerance-verification|4.0.1) Assertion about certainty associated with a propensity, or potential risk, of a reaction to the identified substance.",
          "mapTargetCardinality" : "0..1"
        },
        "/data[at0001]/items[at0101.1]" : {
          "mapTargetName" : "criticality",
          "mapTargetFhirPath" : "AllergyIntolerance.criticality",
          "mapTargetDefinition" : "Estimate of the potential clinical harm, or seriousness, of the reaction to the identified substance.",
          "mapTargetBindings" : "The codes SHALL be taken from AllergyIntoleranceCriticality (required to http://hl7.org/fhir/ValueSet/allergy-intolerance-criticality|4.0.1) Estimate of the potential clinical harm, or seriousness, of a reaction to an identified substance.",
          "mapTargetCardinality" : "0..1"
        },
        "/data[at0001]/items[at0120.1]" : {
          "mapTargetName" : "category",
          "mapTargetFhirPath" : "AllergyIntolerance.category",
          "mapTargetDefinition" : "Category of the identified substance.",
          "mapTargetBindings" : "The codes SHALL be taken from AllergyIntoleranceCategory (required to http://hl7.org/fhir/ValueSet/allergy-intolerance-category|4.0.1) Category of an identified substance associated with allergies or intolerances.",
          "mapTargetCardinality" : "0..*"
        },
        "/data[at0001]/items[at0117.1]" : {
          "mapTargetName" : "lastOccurrence",
          "mapTargetFhirPath" : "AllergyIntolerance.lastOccurrence",
          "mapTargetDefinition" : "Represents the date and/or time of the last known occurrence of a reaction event.",
          "mapTargetCardinality" : "0..1"
        },
        "/data[at0001]/items[at0133.1]" : {
          "mapTargetName" : "onset[x]",
          "mapTargetFhirPath" : "AllergyIntolerance.onset[x]",
          "mapTargetDefinition" : "Estimated or actual date, date-time, or age when allergy or intolerance was identified.",
          "mapTargetCardinality" : "0..1"
        },
        "/data[at0001]/items[at0058.1]" : {
          "mapTargetName" : "type",
          "mapTargetFhirPath" : "AllergyIntolerance.type",
          "mapTargetDefinition" : "Identification of the underlying physiological mechanism for the reaction risk.",
          "mapTargetCardinality" : "0..1"
        },
        "/data[at0001]/items[at0006]" : {
          "mapTargetName" : "note",
          "mapTargetFhirPath" : "AllergyIntolerance.note",
          "mapTargetDefinition" : "Additional narrative about the propensity for the Adverse Reaction, not captured in other fields.",
          "mapTargetCardinality" : "0..*"
        }
      },
