          "mapTargetCardinality" : "0..1",
          "mapTargetBindings" : "SNOMED CT"
        },
        "/description[at0001]/items[at0070.1]" : {
          "mapTargetName" : "reason",
          "mapTargetFhirPath" : "EHDSProcedure.reason[x]",
          "mapTargetDefinition" : "The reason why the procedure was performed. This may be a concept from a terminology or a reference to a specific instance that describes the reason.",
          "mapTargetCardinality" : "0..*",
          "mapTargetBindings" : "SNOMED CT, ICD-10, Orphacode if rare disease is diagnosed"
        },
        "/description[at0001]/items[at0048.1]" : {
          "mapTargetName" : "outcome",
          "mapTargetFhirPath" : "EHDSProcedure.outcome",
          "mapTargetDefinition" : "The outcome of the procedure - did it resolve the reasons for the procedure being performed?",
          "mapTargetCardinality" : "0..1",
          "mapTargetBindings" : "SNOMED CT"
        },
        "/description[at0001]/items[at0006.1]" : {
          "mapTargetName" : "complication",
          "mapTargetFhirPath" : "EHDSProcedure.complication",
          "mapTargetDefinition" : "Any complications that occurred during the procedure, or in the immediate post-performance period. These are generally tracked separately from the procedure description, which will typically describe the procedure itself rather than any 'post procedure' issues.",
          "mapTargetCardinality" : "0..*",
          "mapTargetBindings" : "ICD-10, SNOMED CT, Orphacode if rare disease is diagnosed"
        },
        "/description[at0001]/items[at0005.1]" : {
          "mapTargetName" : "note",
          "mapTargetFhirPath" : "EHDSProcedure.note",
          "mapTargetDefinition" : "Additional information about the procedure",
          "mapTargetCardinality" : "0..1"
        }
      }
    }
