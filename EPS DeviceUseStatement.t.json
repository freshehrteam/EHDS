  "annotations" : {
    "@type" : "RESOURCE_ANNOTATIONS",
    "documentation" : {
      "en" : {
        "" : {
          "mapTargetName" : "DeviceUseStatement",
          "mapTargetFhirPath" : "DeviceUseStatement",
          "mapTargetDefinition" : "A record of a device being used by a patient where the record is the result of a report from the patient or another clinician.",
          "mapTargetCardinality" : "0..*"
        },
        "/data[at0001]/items[at0015.1]" : {
          "mapTargetName" : "text",
          "mapTargetFhirPath" : "DeviceUseStatement.text",
          "mapTargetDefinition" : "A human-readable narrative that contains a summary of the resource and can be used to represent the content of the resource to a human. The narrative need not encode all the structured data, but is required to contain sufficient detail to make it \"clinically safe\" for a human to just read the narrative. Resource definitions may define what content should be represented in the narrative to ensure clinical safety.",
          "mapTargetCardinality" : "0..1"
        },
        "/data[at0001]/items[at0002.1]" : {
          "mapTargetName" : "status",
          "mapTargetFhirPath" : "DeviceUseStatement.status",
          "mapTargetDefinition" : "A code representing the patient or other source's judgment about the state of the device used that this statement is about. Generally this will be active or completed.",
          "mapTargetBindings" : "The codes SHALL be taken from DeviceUseStatementStatus (required to http://hl7.org/fhir/ValueSet/device-statement-status|4.0.1) A coded concept indicating the current status of the Device Usage.",
          "mapTargetCardinality" : "1..1"
        },
        "/data[at0001]/items[at0022]/items[at0008.1]" : {
          "mapTargetName" : "timing[x]:timingPeriod.start",
          "mapTargetFhirPath" : "DeviceUseStatement.timing[x]:timingPeriod.start",
          "mapTargetDefinition" : "The start of the period. The boundary is inclusive.",
          "mapTargetCardinality" : "0..1"
        },
        "/data[at0001]/items[at0022]/items[at0009.1]" : {
          "mapTargetName" : "timing[x]:timingPeriod.end",
          "mapTargetFhirPath" : "DeviceUseStatement.timing[x]:timingPeriod.end",
          "mapTargetDefinition" : "The end of the period. If the end of the period is missing, it means no end was known or planned at the time the instance was created. The start may be in the past, and the end date in the future, which means that period is expected/planned to end at that time.",
          "mapTargetCardinality" : "0..1"
        },
        "/data[at0001]/items[at0022]/items[at0012]" : {
          "mapTargetName" : "bodySite",
          "mapTargetFhirPath" : "DeviceUseStatement.bodySite",
          "mapTargetDefinition" : "Indicates the anotomic location on the subject's body where the device was used ( i.e. the target).",
          "mapTargetBindings" : "The codes SHOULD be taken from SNOMEDCTBodyStructures (preferred to http://hl7.org/fhir/ValueSet/body-site)",
          "mapTargetCardinality" : "0..1"
        }
      }
    }
  },
