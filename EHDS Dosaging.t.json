            },
            "codeString" : "sk"
          },
          "purpose" : "Pre záznam štruktúrovaných informácií o požadovanom časovom rozpise terapeutickej alebo diagnostickej aktivity v rámci 24h intervalu",
          "keywords" : [ "čas", "časový rozpis", "podanie", "dávkovanie", "frekvencia", "interval", "objednávka", "odporúčanie", "rozpis", "za deň", "denne", "denný" ],
          "use" : "Použite pre záznam štruktúrovaných informácií o požadovanom časovom rozpise terapeutickej alebo diagnostickej aktivity v rámci 24h intervalu",
          "misuse" : "Nepoužívajte pre záznam časového rozpisu pre periódy dlhšie ako 24h. V takom prípade použite CLUSTER.timing_repetition archetyp",
