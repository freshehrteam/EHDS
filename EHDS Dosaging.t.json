    "@type" : "TEMPLATE_OVERLAY",
    "uid" : "3d6a52fb-dc86-40a5-a77d-8fa5aaf7c097",
    "description" : {
      "@type" : "RESOURCE_DESCRIPTION",
      "originalAuthor" : { },
