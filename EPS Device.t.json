  "annotations" : {
    "@type" : "RESOURCE_ANNOTATIONS",
    "documentation" : {
      "en" : {
        "" : {
          "mapTargetName" : "Device",
          "mapTargetFhirPath" : "Device",
          "mapTargetDefinition" : "A type of a manufactured item that is used in the provision of healthcare without being substantially changed through that activity. The device may be a medical or non-medical device.",
          "mapTargetCardinality" : "0..*"
        },
        "/items[at0002]" : {
          "mapTargetName" : "text",
          "mapTargetFhirPath" : "Device.text",
          "mapTargetDefinition" : "A human-readable narrative that contains a summary of the resource and can be used to represent the content of the resource to a human. The narrative need not encode all the structured data, but is required to contain sufficient detail to make it \"clinically safe\" for a human to just read the narrative. Resource definitions may define what content should be represented in the narrative to ensure clinical safety.",
          "mapTargetCardinality" : "0..1"
        },
        "/items[at0021]" : {
          "mapTargetName" : "udiCarrier.deviceIdentifier",
          "mapTargetFhirPath" : "Device.udiCarrier.deviceIdentifier",
          "mapTargetDefinition" : "The device identifier (DI) is a mandatory, fixed portion of a UDI that identifies the labeler and the specific version or model of a device.",
          "mapTargetCardinality" : "0..1"
        },
        "/items[at0024.1]" : {
          "mapTargetName" : "identifier",
          "mapTargetFhirPath" : "Device.identifier",
          "MapTargetDefinition" : "Unique instance identifiers assigned to a device by manufacturers other organizations or owners.",
          "mapTargetCardinality" : "0..*"
        },
        "/items[at0024.2]" : {
          "mapTargetName" : "distinctIdentifier",
          "mapTargetFhirPath" : "Device.distinctIdentifier",
          "MapTargetDefinition" : "The distinct identification string as required by regulation for a human cell, tissue, or cellular and tissue-based product.",
          "mapTargetCardinality" : "0..1"
        },
        "/items[at0004]" : {
          "mapTargetName" : "manufacturer",
          "mapTargetFhirPath" : "Device.manufacturer",
          "mapTargetDefinition" : "A name of the manufacturer.",
          "mapTargetCardinality" : "0..1"
        },
        "/items[at0005]" : {
          "mapTargetName" : "manufactureDate",
          "mapTargetFhirPath" : "Device.manufactureDate",
          "mapTargetDefinition" : "The date and time when the device was manufactured.",
          "mapTargetCardinality" : "0..1"
        },
        "/items[at0007]" : {
          "mapTargetName" : "expirationDate",
          "mapTargetFhirPath" : "Device.expirationDate",
          "mapTargetDefinition" : "The date and time beyond which this device is no longer valid or should not be used (if applicable).",
          "mapTargetCardinality" : "0..1"
        },
        "/items[at0006]" : {
          "mapTargetName" : "lotNumber",
          "mapTargetFhirPath" : "Device.lotNumber",
          "mapTargetDefinition" : "Lot number assigned by the manufacturer.",
          "mapTargetCardinality" : "0..1"
        },
        "/items[at0020]" : {
          "mapTargetName" : "serialNumber",
          "mapTargetFhirPath" : "Device.serialNumber",
          "mapTargetDefinition" : "The serial number assigned by the organization when the device was manufactured.",
          "mapTargetCardinality" : "0..1"
        },
        "/items[at0001]" : {
          "mapTargetName" : "deviceName.name",
          "mapTargetFhirPath" : "Device.deviceName.name",
          "mapTargetDefinition" : "The name of the device.",
          "mapTargetCardinality" : "1..1"
        },
        "/items[at0023]" : {
          "mapTargetName" : "modelNumber",
          "mapTargetFhirPath" : "Device.modelNumber",
          "mapTargetDefinition" : "The model number for the device.",
          "mapTargetCardinality" : "0..1"
        },
        "/items[at0003]" : {
          "mapTargetName" : "type",
          "mapTargetFhirPath" : "Device.type",
          "mapTargetDefinition" : "The kind or type of device.",
          "mapTargetBindings" : "The codes SHOULD be taken from Medical Devices - IPS (preferred to http://hl7.org/fhir/uv/ips/ValueSet/medical-devices-uv-ips)",
          "mapTargetCardinality" : "0..1"
        },
        "/items[at0025]" : {
          "mapTargetName" : "version.value",
          "mapTargetFhirPath" : "Device.version.value",
          "mapTargetDefinition" : "The version text.",
          "mapTargetCardinality" : "1..1"
        },
        "/items[at0008]" : {
          "mapTargetName" : "note",
          "mapTargetFhirPath" : "Device.note",
          "mapTargetDefinition" : "Descriptive information, usage information or implantation information that is not captured in an existing element.",
          "mapTargetCardinality" : "0..*"
        }
      }
    }
